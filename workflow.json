{
  "_comment": "HR Payroll Platform — Task 6: monthly_payroll Workflow Definition",
  "_note": "Import this JSON via Databricks REST API: POST /api/2.1/jobs/create",

  "name": "monthly_payroll_assessment_saurav",

  "schedule": {
    "quartz_cron_expression": "0 0 1 1/1 * ? *",
    "timezone_id": "Asia/Kolkata",
    "pause_status": "UNPAUSED"
  },

  "job_clusters": [
    {
      "job_cluster_key": "payroll_job_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.preview.enabled": "true"
        }
      }
    }
  ],

  "email_notifications": {
    "on_failure": ["data-team@company.com"],
    "on_success": ["data-team@company.com"]
  },

  "tasks": [
    {
      "task_key": "ingest_bronze",
      "description": "Step 1 — Read CSVs from /FileStore/tables/hr/raw, write to databricks_assessment_saurav.bronze",
      "job_cluster_key": "payroll_job_cluster",
      "notebook_task": {
        "notebook_path": "/Users/saurav.kumar/hr_payroll/01_bronze_ingestion",
        "base_parameters": {
          "catalog_name": "databricks_assessment_saurav"
        }
      },
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": false,
      "timeout_seconds": 600
    },
    {
      "task_key": "enrich_silver",
      "description": "Step 2 — SCD Type 2 and Enriched Transformation in databricks_assessment_saurav.silver",
      "depends_on": [{ "task_key": "ingest_bronze" }],
      "job_cluster_key": "payroll_job_cluster",
      "notebook_task": {
        "notebook_path": "/Users/saurav.kumar/hr_payroll/02_silver_transformation",
        "base_parameters": {
          "catalog_name": "databricks_assessment_saurav"
        }
      },
      "max_retries": 1,
      "timeout_seconds": 900
    },
    {
      "task_key": "build_gold",
      "description": "Step 3 — Create gold views in databricks_assessment_saurav.gold",
      "depends_on": [{ "task_key": "enrich_silver" }],
      "job_cluster_key": "payroll_job_cluster",
      "notebook_task": {
        "notebook_path": "/Users/saurav.kumar/hr_payroll/03_gold_views",
        "base_parameters": {
          "catalog_name": "databricks_assessment_saurav"
        }
      },
      "max_retries": 1,
      "timeout_seconds": 300
    },
    {
      "task_key": "stream_salary_updates",
      "description": "Step 4 — Auto Loader from /FileStore/tables/hr/streaming/salary_landing",
      "depends_on": [{ "task_key": "build_gold" }],
      "job_cluster_key": "payroll_job_cluster",
      "notebook_task": {
        "notebook_path": "/Users/saurav.kumar/hr_payroll/04_streaming_salary",
        "base_parameters": {
          "catalog_name": "databricks_assessment_saurav"
        }
      },
      "max_retries": 1,
      "timeout_seconds": 600
    }
  ]
}